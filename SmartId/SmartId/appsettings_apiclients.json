				//"LogoUri": "",
				// b102e0fc-ecc8-463b-8fce-6cab1ee3ce7c.ToSha256.ToBase64 https://approsto.com/sha-generator/ + '='
				"ClientSecrets": [ { "Value": "gkof6tRKjoEmHfrAIvVA3FeJbHUb20ZAi1oUQySacNk=" } ],
				"Enabled": true,
				"RequirePkce": false,

