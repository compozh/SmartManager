				// разрешено или нет использовать локальные логины на клиенте
				"EnableLocalLogin": false,
				// какие внешние сервисі авторизации разрешены на клиенте (все, если пусто)
				"IdentityProviderRestrictions": "",
				// можно ограничить время в секундах, в течении которого пользователь может использовать sso без повторного ввода логина
				"UserSsoLifetime": null,

				/* Token */
				// Время жизни токена идентичности в секундах (по умолчанию 300 секунд / 5 минут)
				"IdentityTokenLifetime": 300,
				// Время жизни токена доступа в секундах (по умолчанию 3600 секунд / 1 час)
				"AccessTokenLifetime": 3600,
				// Время жизни кода авторизации в секундах (по умолчанию 300 секунд / 5 минут)
				"AuthorizationCodeLifetime": 300,
				// Максимальное время жизни токена обновления в секундах. По умолчанию 2592000 секунд / 30 дней
				"AbsoluteRefreshTokenLifetime": 2592000,
				// Скользящее время жизни токена обновления в секундах. По умолчанию 1296000 секунд / 15 дней
				"SlidingRefreshTokenLifetime": 1296000,
				// Absolute / Slidingпри
				"RefreshTokenExpiration": "Absolute",
				// Reference / Jwt
				"AccessTokenType": "Jwt",
				// jwt токен имеет уникальный id
				"IncludeJwtId": true,
				// если указан, то будет использоваться службой CORS
				//"AllowedCorsOrigins":,
				// клеймы, которые необходимо включать в тикеты
				"Claims": [ "name" ],
				// Включаются всегда (false - только для credentials flow)
				"AlwaysSendClientClaims": false,
				// Всегда включаются в id token and access token, позволяет не запрашивать userinfo endpoint
				"AlwaysIncludeUserClaimsInIdToken": false,

				/* Consent Screen */
				// Требуется ли экран согласия
				"RequireConsent": true,
				// Разрешено сохранять согласие
				"AllowRememberConsent": true,
				// Срок действия в секундах, 0 - безсрочно
				"ConsentLifetime": 0
