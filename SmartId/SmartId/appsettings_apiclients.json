			},
			{
				// implicit-неявный, client_credentials-передача пароля, hybrid-код авторизации/тикет/рефреш токен
				"AllowedGrantTypes": [ "authorization_code" ],
				// какие области ресурсов разрешено запрашивать на данном клиенте
				"AllowedScopes": [ "openid", "profile" ],
				// разрешено ли клиенту запрашивать токены обновления
				"RequirePkce": true,
				"RequireClientSecret": false,
				"AllowAccessTokensViaBrowser": true,
